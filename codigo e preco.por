programa {
  funcao inicio() {
    real produto1
    inteiro codigopro1
    real produto2
    inteiro codigopro2
  
escreva("codigo do Produto A: ")
leia(codigopro1)
escreva("quantidade: ")
leia(produto1)
real precopro1 = produto1 * 15.30
escreva("codigo do Produto B: ")
leia(codigopro2)
escreva("quantidade: ")
leia(produto2)
real precopro2 = produto2 * 5.20
real precototal = precopro1 + precopro2
escreva("Preço Total: R$" + precototal)

  }
}
