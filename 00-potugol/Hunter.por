programa {
  funcao inicio() {
   escreva("Hunter 350\n")
   inteiro vel = 120
   inteiro pes = 181
   inteiro lit = 13
   inteiro cons = 15 ^ 17
   inteiro consm = 15 + 21
   inteiro ran = consm + cons + lit + pes + vel
   escreva("velocidade maxima: " + vel)
   escreva("\nPeso maximo: " + pes+"kg\n")
   escreva("capacidade do tanque: " + lit + "Lts\n")
   escreva("consumo medio: " + cons + "~" + consm + "km/L\n")
   escreva(ran)

  }
}
