programa {
  funcao inicio() {
    cadeia senha
    escreva("Digite uma Senha: ")
    leia(senha)
    se(senha == "abracadabra"){
escreva("MENSAGEM SEGRETA!:\n")
escreva("************ **** *** ******** *** ******** <3")
    cadeia senhaCon
      escreva("\nConfirma a senha:")
      leia(senhaCon)
limpa()
      escreva("Usuario Creado")
    }
    senao{
      cadeia senhaCon
      escreva("Confirma a senha:")
      leia(senhaCon)
      limpa()
      escreva("Usuario Creado")
    }
  }
}
