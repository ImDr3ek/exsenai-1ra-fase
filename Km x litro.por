programa {
  funcao inicio() {
    
real kmpercorridos
real litrosgastos
escreva("Quantos KM foram rodados: ")
leia(kmpercorridos)
escreva("Quantos litros foram consumidos: ")
leia(litrosgastos)
real mediagastos = (kmpercorridos / litrosgastos)
escreva("Qual é o cosnumo de litro por km rodado: " + mediagastos)

  }
}
