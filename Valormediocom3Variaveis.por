programa {
  funcao inicio() {
    real valorA, valorB, valorC
    escreva("Valor A: ")
    leia(valorA)
    escreva("Valor B: ")
    leia(valorB)
    escreva("Valor C: ")
    leia(valorC)
    limpa()
    real mediaAB = (valorA * 2.0 + valorB * 3.0 + valorC * 5 ) / 10
    escreva("Media Total: " + mediaAB)
  }
}
