programa {
  funcao inicio() {
    inteiro a
    inteiro b
    escreva("Numero A: ")
    leia(a)
    escreva("Numeor B: ")
    leia(b)
    se(a>b){
      escreva("numero A maior do que B " + a + ">" + b)
    }
    senao{

    }se(a<b){
      escreva("numero B maior do que A " + b + ">" + a)
      
    }senao{
      se(a==b){
      escreva("numeros iguais " + a + "=" +b) }
    }

  }
}
